{% extends "_base.njk" %}

{% block main %}
<div class="namespace">
    <h1>
        <small class="block">Have you tried...</small>
        {{ title }}
    </h1>

    <a href="https://google.com/search?q={{ title + ', ' + (address if address else "Sault Ste. Marie") | urlencode }}" target="_blank">
        View on Google<svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="16"><path d="M376 64L352 64L352 112L494.1 112L263.1 343L246.1 360L280 393.9L297 376.9L528 145.9L528 288L576 288L576 64L376 64zM88 160L64 160L64 576L480 576L480 384L432 384L432 528L112 528L112 208L256 208L256 160L88 160z"/></svg>
    </a>
</div>

<button id="roll" type="button">Re-roll</button>

<p id="status-message"></p>

<dl class="container">
    <dt>Location{{ 's' if (locations and locations.length > 1) }}</dt>
    <dd>
        {% for loc in locations %}
            <div class="location">
                {% if loc.address %}
                    <a href="https://maps.google.com/?q={{ title + ', ' + loc.address | urlencode }}" target="_blank">{{ loc.address }}</a>
                {% endif %}
                
                {% if loc.hours %}
                    <details style="margin-top: 0.5rem">
                        <summary class="status" data-hours='{{ loc.hours | dump }}'>
                            Expand hours
                        </summary>
                        <ul class="hours">
                            {% for day, time in loc.hours %}
                                <li class="{% if day == currentDay %}is-today{% endif %}"><strong>{{ day }}:</strong> {{ time }}</li>
                            {% endfor %}
                        </ul>
                    </details>
                {% else %}
                    <p style="margin-top: 0.5rem"><em>No hours listed</em></p>
                {% endif %}
            </div>
        {% endfor %}
    </dd>

    <dt>Tags</dt>
    <dd>
        {% if tags and tags.length > 0 %}
            {% for tag in tags %}
                <a href="https://google.ca/search?q={{ tag + ' sault ste marie' | urlencode }}" target="_blank" class="tag">{{ tag }}</a>
            {% endfor %}
        {% endif %}
    </dd>
    

    <dt>Description</dt>
    <dd>
        {{ description | safe if description }}
    </dd>
</dl>

<p style="margin: 3rem 0 0;">
    <small>Wrong info? <a href="https://github.com/dohnutt/soo-supper-suggester/edit/main/src/restaurants/{{ page.fileSlug }}.md" target="_blank">Edit on GitHub</a></small>
</p>
{% endblock %}

{% block footer %}
<p class="hit-counter">
    Saultites have rolled<br> <img src="https://profile-counter.deno.dev/soo-supper-suggester/count.svg" alt="Hit Counter"/> <br>times
</p>
{% endblock %}

{% block scripts %}
<script>
function renderHours() {
    const mainEl = document.getElementsByTagName('main')[0];
    if (typeof isOpenNow !== 'function') return;

    const days = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
    const now = new Date();
    const todayName = days[now.getDay()];

    let anyOpen = false;
    let anyMaybe = false;
    
    const locSummaries = document.querySelectorAll('.status');
    
    if (locSummaries.length > 0) {
        locSummaries.forEach(summary => {
            let locHours = null;
            try { 
                locHours = JSON.parse(summary.getAttribute('data-hours')); 
            } catch(e) {}

            const status = isOpenNow(locHours);
            const todayHours = (locHours && locHours[todayName]) ? locHours[todayName] : "Unknown hours";

            if (status === true) {
                anyOpen = true;
                summary.innerHTML = `<strong>Open now</strong>, ${todayHours}`;
            } else if (status === false) {
                summary.innerHTML = `<strong>Closed</strong>, ${todayHours}`;
            } else {
                anyMaybe = true;
                summary.innerHTML = `<em>Maybe open?</em> (No hours listed)`;
            }
        });
    } else {
        anyMaybe = true;
    }

    if (anyOpen) {
        mainEl.classList.add('is-open');
    } else if (!anyOpen && !anyMaybe) {
        mainEl.classList.add('is-closed');
    } else {
        mainEl.classList.add('is-maybe');
    }
    
    // Highlight today in lists
    const listItems = document.querySelectorAll('.hours li');
    listItems.forEach(li => {
        if (li.textContent.startsWith(todayName)) {
            li.classList.add('is-today');
        }
    });
}

renderHours();
</script>
{% endblock %}