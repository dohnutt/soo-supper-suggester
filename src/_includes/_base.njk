<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="Sault Ste. Marie is full of great places to eat, but making a decision can be tough. Hit the button to roll a suggestion.">
    <meta property="og:image" content="https://soo-supper-suggester.netlify.app/share-image.png" />
    <meta property="og:title" content="{{ title }}" />
    <meta property="og:description" content="Sault Ste. Marie is full of great places to eat, but making a decision can be tough. Hit the button to roll a suggestion." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://soo-supper-suggester.netlify.app" />
    <meta property="og:site_name" content="Soo Supper Suggester" />
    <meta property="og:locale" content="en_CA" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main>
        {%- block main -%}
            {{ content | safe }}
        {%- endblock -%}
    </main>

    
    <footer>
        {% block footer %}{% endblock %}
        
        <a href="https://madeinthesoo.ca/">Made in the Soo 🇨🇦</a>
        <span class="sep" aria-hidden="true">•</span>
        <a href="https://dohnutt.com">Built by 🍩</a>
    </footer>
    

    
    <script src="/script.js"></script>
    {%- block scripts %}{% endblock %}
</body>
</html>